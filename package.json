{
    "$schema": "https://json.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build && npm run build:theme",
        "dev": "concurrently \"vite\" \"npm run watch:theme\"",
        "build:theme": "npx tailwindcss@3 --input ./resources/css/filament/admin/theme.css --output ./public/css/filament/admin/theme.css --config ./resources/css/filament/admin/tailwind.config.js --minify",
        "watch:theme": "npx tailwindcss@3 --input ./resources/css/filament/admin/theme.css --output ./public/css/filament/admin/theme.css --config ./resources/css/filament/admin/tailwind.config.js --watch",
        "inertia:build": "vite build",
        "inertia:dev": "vite"
    },
    "dependencies": {
        "@formkit/drag-and-drop": "^0.5.3",
        "@inertiajs/core": "^1.2.0",
        "@inertiajs/vue3": "^1.2.0",
        "@tanstack/vue-form": "^1.0.0",
        "@tanstack/vue-table": "^8.21.2",
        "@types/leaflet": "^1.9.21",
        "@vee-validate/zod": "^4.15.0",
        "@vueuse/core": "^12.5.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "laravel-echo": "^1.19.0",
        "leaflet": "^1.9.4",
        "lucide-vue-next": "^0.474.0",
        "pinia": "^3.0.1",
        "pusher-js": "^8.4.0",
        "recharts": "^2.15.1",
        "tailwind-merge": "^2.6.0",
        "tailwindcss-animate": "^1.0.7",
        "vee-validate": "^4.15.0",
        "vue": "^3.5.13",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@tailwindcss/forms": "^0.5.10",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.0.0",
        "@types/node": "^22.13.4",
        "@vitejs/plugin-vue": "^6.0.5",
        "autoprefixer": "^10.4.22",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^1.0.0",
        "postcss": "^8.5.6",
        "tailwindcss": "^3.4.18",
        "typescript": "^5.7.3",
        "vite": "^6.0.0",
        "vue-tsc": "^2.2.0"
    },
    "overrides": {
        "vite": "^6.0.0"
    }
}
